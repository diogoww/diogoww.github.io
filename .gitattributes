# Padronizar todos os arquivos de texto para LF
* text=auto eol=lf

# Arquivos de código sempre tratados como texto
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.xml  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Scripts (caso use futuramente)
*.sh   text eol=lf
*.bat  text eol=crlf

# Arquivos binários (não devem sofrer conversão de fim de linha)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.svg  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.mp4  binary
*.mp3  binary